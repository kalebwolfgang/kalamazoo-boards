{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kalebwolfgang.github.io/kalamazoo-boards/schemas/changelog.schema.json",
  "title": "Kalamazoo Boards — build changelog",
  "description": "Schema for data/changelog.json written by build.py at the end of each run.",
  "type": "object",
  "required": ["timestamp", "runId", "validationPassed", "changes"],
  "additionalProperties": false,
  "properties": {
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of the build run (UTC)."
    },
    "runId": {
      "type": "string",
      "minLength": 1,
      "description": "Short unique identifier for this run."
    },
    "validationPassed": {
      "type": "boolean",
      "description": "True if all schema validations passed before the build step."
    },
    "changes": {
      "type": "array",
      "items": { "$ref": "#/$defs/boardChangeSummary" }
    }
  },
  "$defs": {
    "boardChangeSummary": {
      "type": "object",
      "required": ["board", "meetings", "upcoming"],
      "additionalProperties": false,
      "properties": {
        "board":    { "type": "string", "minLength": 1 },
        "meetings": { "type": "integer", "minimum": 0 },
        "upcoming": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
